# =============================================================
#  ENVIRONMENT VARIABLES TEMPLATE — Copy to .env to use
# =============================================================
# This file shows the expected format for environment variables.
# Copy this to .env and fill in your actual values.
# Never commit .env to git — it contains sensitive credentials.
#
# HOW TO USE:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your actual API keys and settings
# 3. The application will automatically load from .env
#
# LOCAL DEVELOPMENT: Create .env.local for machine-specific settings
# HOSTINGER/PRODUCTION: Set environment variables in Hostinger control panel
#   → Go to: SSH Terminal → Environment Variables (or similar)
#   → Or set them in your deployment script

# ── Anthropic API ─────────────────────────────────────────────
# Get your API key at: https://console.anthropic.com/settings/keys
# Required: Must be set before the app can generate documents
ANTHROPIC_API_KEY=sk-ant-v...

# ── Model selection ───────────────────────────────────────────
# Options (best → cheapest):
#   claude-opus-4-6    ~$0.40–0.80 per document  (best quality)
#   claude-sonnet-4-6  ~$0.10–0.20 per document  (great quality, recommended)
#   claude-haiku-4-5   ~$0.03–0.06 per document  (good for drafts)
MODEL=claude-sonnet-4-6

# ── Email delivery configuration ───────────────────────────────
# SMTP server settings
# For Gmail:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your_email@gmail.com
#   SMTP_PASSWORD=your_16_char_app_password (not your login password)
#   → Generate at: https://myaccount.google.com/apppasswords
#
# For other providers (Outlook, Yahoo, etc.), update accordingly

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# Email recipients
# Generated .docx files will be automatically emailed to these addresses
# (in addition to any per-job recipient specified in the web form)
RECIPIENT_EMAIL_1=recipient1@example.com
RECIPIENT_EMAIL_2=recipient2@example.com

# ── Optional: Machine-specific overrides ────────────────────────
# For local development, you can create .env.local with machine-specific values
# .env.local is gitignored and loaded AFTER .env
# Example: different API keys for dev vs. staging
#
# FILE: .env.local
# ANTHROPIC_API_KEY=sk-ant-dev-key-for-local-testing
